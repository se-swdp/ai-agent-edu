{
  "hosting": [
    {
      "target": "default",
      "public": "redirect",
      "ignore": [
        "firebase.json",
        ".firebaserc",
        "**/.*",
        "**/node_modules/**"
      ],
      "redirects": [
        {
          "source": "/:path*",
          "destination": "https://ai-agent-edu.web.app/:path*",
          "type": 301
        }
      ]
    },
    {
      "target": "agent",
      "public": ".",
      "predeploy": [
        "node scripts/build-materials-manifest.mjs"
      ],
      "ignore": [
        "firebase.json",
        ".firebaserc",
        ".firebase/**",
        "**/.*",
        "**/node_modules/**",
        "README.md",
        "**/README.md",
        "HANDOFF.md",
        "**/HANDOFF.md",
        "**/REVIEW-FEEDBACK.md",
        "firestore.rules",
        "firestore.indexes.json",
        "*-firebase-adminsdk-*.json",
        "serviceAccountKey*.json",
        "**/src-png/**"
      ],
      "cleanUrls": true,
      "headers": [
        {
          "source": "**/*.@(jpg|jpeg|png|webp|svg|woff2)",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "public, max-age=31536000, immutable"
            }
          ]
        },
        {
          "source": "**/*.@(css|js)",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache"
            }
          ]
        },
        {
          "source": "**/*.html",
