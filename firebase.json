{
  "hosting": [
    {
      "target": "default",
      "public": "redirect",
      "ignore": [
        "firebase.json",
        ".firebaserc",
        "**/.*",
        "**/node_modules/**"
      ],
      "redirects": [
        {
          "source": "/:path*",
          "destination": "https://ai-agent-edu.web.app/:path*",
          "type": 301
        }
      ]
    },
    {
      "target": "agent",
      "public": ".",
      "predeploy": [
        "node scripts/build-materials-manifest.mjs"
      ],
      "ignore": [
        "firebase.json",
        ".firebaserc",
        ".firebase/**",
        "**/.*",
        "**/node_modules/**",
        "README.md",
        "**/README.md",
        "HANDOFF.md",
        "**/HANDOFF.md",
        "firestore.rules",
        "firestore.indexes.json",
        "*-firebase-adminsdk-*.json",
        "serviceAccountKey*.json",
        "**/src-png/**"
      ],
      "cleanUrls": true,
      "headers": [
        {
          "source": "**/*.@(jpg|jpeg|png|webp|svg|woff2)",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "public, max-age=31536000, immutable"
            }
          ]
        },
        {
          "source": "**/*.@(css|js)",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache"
            }
          ]
        },
        {
          "source": "**/*.html",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-store"
            }
          ]
        }
      ],
      "redirects": [
        {
          "source": "/presentations/guru-notes-2026",
          "destination": "/presentations/ai-checkpoint-2026-07/",
          "type": 301
        },
        {
          "source": "/presentations/guru-notes-2026/",
          "destination": "/presentations/ai-checkpoint-2026-07/",
          "type": 301
        },
        {
          "source": "/presentations/guru-notes-2026/:rest*",
          "destination": "/presentations/ai-checkpoint-2026-07/:rest*",
          "type": 301
        }
      ]
    }
  ],
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  }
}
